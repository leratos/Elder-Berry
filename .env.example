# Elder-Berry – Umgebungsvariablen
# Kopiere diese Datei nach .env und trage deine Werte ein.
# .env wird NICHT ins Repo eingecheckt.

# OpenRouter API-Key (https://openrouter.ai → Keys)
OPENROUTER_API_KEY=

# Ollama-Endpunkt (Standard: lokal – nur ändern wenn Ollama auf anderem Host läuft)
# OLLAMA_BASE_URL=http://localhost:11434

# Ollama-Modell (Standard: llama3.1:14b)
# OLLAMA_MODEL=llama3.1:14b

# OpenRouter-Modell (Standard: meta-llama/llama-3.1-70b-instruct)
# OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct
