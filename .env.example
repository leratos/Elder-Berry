# Elder-Berry – Umgebungsvariablen
# Kopiere diese Datei nach .env und trage deine Werte ein.
# .env wird NICHT ins Repo eingecheckt.

# ── Primäres LLM-Backend: Anthropic API ─────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Anthropic-Modell (Standard: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Offline-Fallback: Ollama (lokal) ────────────────────────────────────────
# Nur ändern wenn Ollama auf einem anderen Host läuft (z.B. Tower über Meshnet)
# OLLAMA_BASE_URL=http://localhost:11434

# Ollama-Modell (Standard: phi4:14b)
# OLLAMA_MODEL=phi4:14b

# ── OpenRouter (optional, für Modell-Experimente) ───────────────────────────
# https://openrouter.ai → Keys
# OPENROUTER_API_KEY=

# ── RAG / Memory ────────────────────────────────────────────────────────────
# Pfad zur ChromaDB-Datenbank (Standard: ~/.elder-berry/memory/)
# MEMORY_DB_PATH=~/.elder-berry/memory

# Ollama-Embedding-Modell für semantische Suche (Standard: nomic-embed-text)
# EMBEDDING_MODEL=nomic-embed-text
