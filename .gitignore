# Elder-Berry - Git Ignore File

# ============================================================================
# PYTHON
# ============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
.env/

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# mypy
.mypy_cache/
backend/.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# Ruff cache
.ruff_cache/

# pre-commit
.pre-commit-cache/

# ============================================================================
# ENVIRONMENT VARIABLES
# ============================================================================
.env
.env.local
.env.production
.env.test
*.env

# Keep example files
!.env.example

# ============================================================================
# DATABASE
# ============================================================================
# SQLite databases
*.db
*.sqlite
*.sqlite3

# Database dumps
*.sql
*.dump

# ChromaDB data
chroma_data/

# ============================================================================
# IDE / EDITORS
# ============================================================================
# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ============================================================================
# OS
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ============================================================================
# DOCKER
# ============================================================================
# Docker volumes
docker-volumes/

# ============================================================================
# LOGS
# ============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================================
# TEMPORARY FILES
# ============================================================================
tmp/
temp/
*.tmp
*.bak
*.swp
OldVersions/

# ============================================================================
# SECRETS & KEYS
# ============================================================================
# API Keys
*_key.txt
*_secret.txt
secrets/

# SSL Certificates
*.pem
*.key
*.crt

# ============================================================================
# PROJECT-SPECIFIC
# ============================================================================
# Alembic (keep structure, ignore auto-generated)
# alembic/versions/*.py  # Uncomment if you want to ignore migrations

# User uploads (if any)
uploads/

# Cache directories
.cache/
cache/

# Output files
outputs/
exports/

# Personal notes / task lists
docs/personal/

# ============================================================================
# KEEP THESE FILES
# ============================================================================
!.gitkeep
!.env.example
!README.md
# Saleria instance lock
.saleria.lock
.claude/settings.json
config/harmony_config_backup.json
server/borg-backup.sh
scripts/Install-SshTunnelTask.ps1
scripts/ssh-tunnel.ps1
.claude/worktrees/elated-morse
