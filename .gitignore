docker-volumes/

# ============================================================================
# LOGS
# ============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================================
# TEMPORARY FILES
# ============================================================================
tmp/
temp/
*.tmp
*.bak
*.swp
# Generischer OldVersions/-Schutz (matcht ueberall im Repo)
OldVersions/
# Expliziter Eintrag fuer hardware/enclosure/OldVersions/ -- Inventor
# legt dort Backup-Versionen (.0001.ipt, .0002.iam, ...) ab. Lokal ~129 MB,
# darf NIE ins Public-Repo. Doppelt gehalten als Schutz, falls oben
# das generische Pattern spaeter entfernt wird.
hardware/enclosure/OldVersions/

# ============================================================================
# Public-Readiness Blocklist (Phase 71)
# ============================================================================
# Maintainer-spezifische Such-Patterns (Domains, Namen, Hostnames).
# .example.txt ist getrackt und dient als Vorlage.
.public-readiness-blocklist.txt

# ============================================================================
# SECRETS & KEYS
# ============================================================================
# API Keys
*_key.txt
*_secret.txt
secrets/

# SSL Certificates
*.pem
*.key
*.crt

# ============================================================================
# PROJECT-SPECIFIC
# ============================================================================
# Alembic (keep structure, ignore auto-generated)
# alembic/versions/*.py  # Uncomment if you want to ignore migrations

# User uploads (if any)
uploads/

# Cache directories
.cache/
cache/

# Output files
outputs/
exports/

# Personal notes / task lists
docs/personal/

# ============================================================================
# KEEP THESE FILES
# ============================================================================
!.gitkeep
!.env.example
!README.md
# Saleria instance lock
.saleria.lock
.claude/settings.json
.claude/settings.local.json
config/harmony_config_backup.json
server/borg-backup.sh
scripts/Install-SshTunnelTask.ps1
scripts/ssh-tunnel.ps1
.claude/worktrees/

# Phase 67: Public-Readiness-Audit-Output (regenerierbar via
# scripts/check_public_readiness.py).
docs/public-readiness-audit.md
audit-tmp.json

# Phase 67: deployment-spezifisches Backup-Skript bleibt lokal.
server/borg-backup.sh

# Phase 67: journal.txt bleibt lokal als Workflow-Tool, ist ab
# diesem Commit nicht mehr im oeffentlichen Repo. Siehe
# docs/CHANGELOG.md fuer die kuratierte Phasen-Story.
docs/journal.txt
